{
    "name":  "gapflush-live",
    "version":  "1.0.0",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder --win"
                },
    "keywords":  [

                 ],
    "author":  "Shreyash Chaudhari",
    "license":  "ISC",
    "description":  "Async File processing with a Dashboard",
    "dependencies":  {
                         "chokidar":  "^5.0.0"
                     },
    "devDependencies":  {
                            "electron":  "^41.7.0",
                            "electron-builder":  "^26.15.3"
                        },
    "build":  {
                  "appId":  "com.tpem.gapflush",
                  "productName":  "GapFlush TPEM",
                  "directories":  {
                                      "output":  "C:\\GapflushBuild"
                                  },
                  "win":  {
                              "target":  "nsis"
                          },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "package.json",
                                "src/**/*",
                                "Source_TXT_FILE/**/*",
                                "Desired_TXT_FILE/**/*",
                                "node_modules/**/*"
                            ]
              }
}